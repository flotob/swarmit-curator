# Chain
RPC_URL=https://rpc.gnosischain.com
CONTRACT_ADDRESS=0xf759cD44a0d477E4e593468993ffbD935FD838bc
CONTRACT_DEPLOY_BLOCK=45658410
CONFIRMATIONS=12
POLL_INTERVAL=30

# Swarm
BEE_URL=http://localhost:1633
POSTAGE_BATCH_ID=

# Curator identity
# This key is used for: feed signing, curatorProfile.curator, and CuratorDeclared msg.sender.
# All three MUST be the same identity.
CURATOR_PRIVATE_KEY=
CURATOR_NAME=Chronological Curator
CURATOR_DESCRIPTION=Spam-filtered chronological board views

# State (rebuildable cache — chain + Swarm are the source of truth)
STATE_FILE=./state.json
